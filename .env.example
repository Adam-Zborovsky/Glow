# Database (Use localhost:8181 for host-machine access via Docker)
DATABASE_URL="postgresql://postgres:postgres@localhost:8181/glow?schema=public"
# Override for docker-compose — sets the Postgres superuser password
# POSTGRES_PASSWORD=postgres

# Next Auth
# Generate one here: https://generate-secret.vercel.app/32
AUTH_SECRET="yoursupersecretsecret"
# When running in production or behind a proxy (Cloudflare), set this to your public domain
# e.g., AUTH_URL="https://glow.yourdomain.com"
AUTH_URL="http://localhost:3000"

# Google Auth
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
